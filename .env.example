# Environment configuration for pflaenzli_backend.
# Copy to `.env` and adjust. `.env` is gitignored; never commit real secrets.
# All variables below are REQUIRED — settings.py has no defaults, so the app fails to
# start if any is missing.

# --- Development example values ---

# Debug pages + verbose errors. NEVER true in production.
DEBUG=True

# Generate a real one for production, e.g.:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-i2vk@*mq@#paxolpjih2y#mm0&-3+iizm_@gs*efa%z59)wzdr

# Comma-separated. Production: the server IP / domain (and ngrok host if used).
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated, scheme required. Production: the deployed frontend origin.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Whether the backend actually talks to the Arduino over HTTP.
# Dev without hardware: False (pump/config calls are no-ops). Production: True.
ARDUINO_ENABLED=False

# The Arduino's address on the network (used only when ARDUINO_ENABLED=True).
ARDUINO_ADDRESS=192.168.68.112
